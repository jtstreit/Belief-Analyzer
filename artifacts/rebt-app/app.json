{
  "expo": {
    "name": "Belief Analyzer",
    "slug": "belief-analyzer",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "belief-analyzer",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.streitwieserj92.beliefanalyzer",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FAFAF7"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#FAFAF7",
      "barStyle": "dark-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#FAFAF7",
      "barStyle": "dark-content"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
